public class QuickSort {
    /**
     * 快速排序主方法
     * @param arr 待排序的整型数组
     */
    public static void quickSort(int[] arr) {
        if (arr == null || arr.length <= 1) {
            return;
        }
        quickSort(arr, 0, arr.length - 1);
    }

    /**
     * 快速排序递归实现
     * @param arr 待排序数组
     * @param low 起始索引
     * @param high 结束索引
     */
    private static void quickSort(int[] arr, int low, int high) {
        if (low < high) {
            // 获取分区点
            int pivotIndex = partition(arr, low, high);
            // 递归排序左半部分
            quickSort(arr, low, pivotIndex - 1);
            // 递归排序右半部分
            quickSort(arr, pivotIndex + 1, high);
        }
    }

    /**
     * 分区操作：将数组分为小于等于pivot和大于pivot的两部分
     * @param arr 待排序数组
     * @param low 起始索引
     * @param high 结束索引
     * @return pivot的最终位置
     */
    private static int partition(int[] arr, int low, int high) {
        // 选择最后一个元素作为pivot
        int pivot = arr[high];
        int i = low - 1; // 小于等于pivot的元素的索引

        for (int j = low; j < high; j++) {
            // 如果当前元素小于等于pivot
            if (arr[j] <= pivot) {
                i++;
                swap(arr, i, j);
            }
        }
        // 将pivot放到正确位置
        swap(arr, i + 1, high);
        return i + 1;
    }

    /**
     * 交换数组中两个位置的元素
     * @param arr 数组
     * @param i 索引1
     * @param j 索引2
     */
    private static void swap(int[] arr, int i, int j) {
        int temp = arr[i];
        arr[i] = arr[j];
        arr[j] = temp;
    }
}
```, - **Correctness**: The implementation is logically correct and follows the standard Lomuto partition scheme. It correctly sorts arrays in-place.
- **Readability**: Code is well-structured, well-documented with clear Javadoc, and follows Java naming and style conventions.
- **Efficiency**: Time complexity is O(n²) worst-case (e.g., already-sorted array), which is inherent to basic quicksort; no optimizations (e.g., randomized pivot, median-of-three) are included — acceptable for a basic implementation but worth noting for production use.
- **Edge Cases**: Handles `null` and arrays of length ≤ 1 correctly. However, it does not guard against integer overflow in index calculations (not a practical concern here, but technically possible in extreme cases).
- **Best Practices**: Uses `private static` helper methods appropriately; avoids side effects; no unnecessary object creation. Consider adding `@param`/`@return` consistency (e.g., `swap` lacks `@return` — harmless since it's void, but minor inconsistency)., ```java
public class QuickSort {
    /**
     * 快速排序主方法
     * @param arr 待排序的整型数组
     */
    public static void quickSort(int[] arr) {
        if (arr == null || arr.length <= 1) {
            return;
        }
        quickSort(arr, 0, arr.length - 1);
    }

    /**
     * 快速排序递归实现
     * @param arr 待排序数组
     * @param low 起始索引
     * @param high 结束索引
     */
    private static void quickSort(int[] arr, int low, int high) {
        if (low < high) {
            // 获取分区点
            int pivotIndex = partition(arr, low, high);
            // 递归排序左半部分
            quickSort(arr, low, pivotIndex - 1);
            // 递归排序右半部分
            quickSort(arr, pivotIndex + 1, high);
        }
    }

    /**
     * 分区操作：将数组分为小于等于pivot和大于pivot的两部分
     * @param arr 待排序数组
     * @param low 起始索引
     * @param high 结束索引
     * @return pivot的最终位置
     */
    private static int partition(int[] arr, int low, int high) {
        // 选择最后一个元素作为pivot
        int pivot = arr[high];
        int i = low - 1; // 小于等于pivot的元素的索引

        for (int j = low; j < high; j++) {
            // 如果当前元素小于等于pivot
            if (arr[j] <= pivot) {
                i++;
                swap(arr, i, j);
            }
        }
        // 将pivot放到正确位置
        swap(arr, i + 1, high);
        return i + 1;
    }

    /**
     * 交换数组中两个位置的元素
     * @param arr 数组
     * @param i 索引1
     * @param j 索引2
     */
    private static void swap(int[] arr, int i, int j) {
        int temp = arr[i];
        arr[i] = arr[j];
        arr[j] = temp;
    }
}
