public class QuickSort {
    // 主要的快速排序方法
    public static void quickSort(int[] arr, int low, int high) {
        if (low < high) {
            // 获取分区点
            int pivotIndex = partition(arr, low, high);
            
            // 递归排序左半部分
            quickSort(arr, low, pivotIndex - 1);
            
            // 递归排序右半部分
            quickSort(arr, pivotIndex + 1, high);
        }
    }
    
    // 分区方法：将数组分为小于和大于基准值的两部分
    private static int partition(int[] arr, int low, int high) {
        // 选择最后一个元素作为基准值
        int pivot = arr[high];
        
        // 较小元素的索引
        int i = low - 1;
        
        for (int j = low; j < high; j++) {
            // 如果当前元素小于或等于基准值
            if (arr[j] <= pivot) {
                i++;
                // 交换 arr[i] 和 arr[j]
                int temp = arr[i];
                arr[i] = arr[j];
                arr[j] = temp;
            }
        }
        
        // 将基准值放到正确位置
        int temp = arr[i + 1];
        arr[i + 1] = arr[high];
        arr[high] = temp;
        
        return i + 1;
    }
    
    // 便捷方法：对整个数组进行排序
    public static void quickSort(int[] arr) {
        if (arr != null && arr.length > 0) {
            quickSort(arr, 0, arr.length - 1);
        }
    }
}
```, - **Correctness**: The partition logic is correct and follows the Lomuto scheme; however, the worst-case time complexity O(n²) occurs with already-sorted or reverse-sorted arrays — consider randomizing the pivot selection to mitigate this.
- **Readability**: Code is well-commented and follows standard Java naming/style conventions; minor improvement: use `final` for `pivot` in `partition` to signal immutability.
- **Efficiency**: No explicit optimization for small subarrays (e.g., switching to insertion sort for `high - low < 10`) — adding this would improve real-world performance.
- **Edge Cases**: Handles `null` and empty arrays correctly in the convenience method, but `quickSort(arr, low, high)` lacks input validation — calling it with invalid indices (e.g., `low > high`, out-of-bounds) may throw `ArrayIndexOutOfBoundsException`.
- **Best Practices**: Missing Javadoc for public methods; consider adding `@param` and `@throws` documentation. Also, the class has no constructor and is stateless — making it `final` and adding a private constructor would prevent instantiation and clarify intent., ```java
import java.util.Random;

/**
 * A utility class providing quick sort implementations.
 * This class implements the quick sort algorithm with optimizations including:
 * <ul>
 *   <li>Randomized pivot selection to avoid worst-case O(n²) performance</li>
 *   <li>Hybrid approach using insertion sort for small subarrays (size < 10)</li>
 *   <li>Input validation for robustness</li>
 * </ul>
 *
 * @author CodeRefactorerAgent
 */
public final class QuickSort {
    private static final int INSERTION_SORT_THRESHOLD = 10;
    private static final Random RANDOM = new Random();

    // Prevent instantiation of this utility class
    private QuickSort() {}

    /**
     * Sorts the specified array into ascending numerical order.
     *
     * @param arr the array to be sorted, may be {@code null}
     * @throws IllegalArgumentException if the array contains invalid indices
     */
    public static void quickSort(int[] arr) {
        if (arr != null && arr.length > 0) {
            quickSort(arr, 0, arr.length - 1);
        }
    }

    /**
     * Sorts the specified range of the array into ascending numerical order.
     * The range to be sorted extends from index {@code low} (inclusive) to
     * index {@code high} (inclusive).
     *
     * @param arr the array to be sorted
     * @param low the index of the first element, inclusive, to be sorted
     * @param high the index of the last element, inclusive, to be sorted
     * @throws IllegalArgumentException if {@code low > high} or if either index is out of bounds
     * @throws NullPointerException if {@code arr} is {@code null}
     */
    public static void quickSort(int[] arr, int low, int high) {
        // Input validation
        if (arr == null) {
            throw new NullPointerException("Array cannot be null");
        }
        if (low > high) {
            throw new IllegalArgumentException("Low index cannot be greater than high index");
        }
        if (low < 0 || high >= arr.length || low >= arr.length || high < 0) {
            throw new IllegalArgumentException("Index out of bounds: low=" + low + ", high=" + high + ", array length=" + arr.length);
        }

        if (low < high) {
            // Use insertion sort for small subarrays
            if (high - low + 1 < INSERTION_SORT_THRESHOLD) {
                insertionSort(arr, low, high);
                return;
            }

            // Randomize pivot selection to avoid worst-case performance
            int randomIndex = RANDOM.nextInt(high - low + 1) + low;
            swap(arr, randomIndex, high);

            // Get partition index
            int pivotIndex = partition(arr, low, high);

            // Recursively sort left and right partitions
            quickSort(arr, low, pivotIndex - 1);
            quickSort(arr, pivotIndex + 1, high);
        }
    }

    /**
     * Partitions the array around a pivot element.
     * Uses Lomuto partition scheme with the pivot as the last element.
     *
     * @param arr the array to partition
     * @param low the lower bound index (inclusive)
     * @param high the upper bound index (inclusive)
     * @return the final position of the pivot element
     */
    private static int partition(int[] arr, int low, int high) {
        // Select pivot (already randomized before calling this method)
        final int pivot = arr[high];

        int i = low - 1;

        for (int j = low; j < high; j++) {
            if (arr[j] <= pivot) {
                i++;
                swap(arr, i, j);
            }
        }

        swap(arr, i + 1, high);
        return i + 1;
    }

    /**
     * Performs insertion sort on the specified range of the array.
     *
     * @param arr the array to sort
     * @param low the lower bound index (inclusive)
     * @param high the upper bound index (inclusive)
     */
    private static void insertionSort(int[] arr, int low, int high) {
        for (int i = low + 1; i <= high; i++) {
            int key = arr[i];
            int j = i - 1;

            while (j >= low && arr[j] > key) {
                arr[j + 1] = arr[j];
                j--;
            }
            arr[j + 1] = key;
        }
    }

    /**
     * Swaps two elements in the array.
     *
     * @param arr the array containing the elements to swap
     * @param i the index of the first element
     * @param j the index of the second element
     */
    private static void swap(int[] arr, int i, int j) {
        if (i != j) {
            int temp = arr[i];
            arr[i] = arr[j];
            arr[j] = temp;
        }
    }
}
