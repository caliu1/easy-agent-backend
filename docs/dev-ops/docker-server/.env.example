APP_IMAGE_TAG=latest
TZ=Asia/Shanghai

# standalone: run mysql+backend+frontend+gateway
# reuse: reuse existing mysql/nginx, run backend+frontend only
DEPLOY_MODE=standalone

# 推荐：填写阿里云镜像全名（服务器将直接 pull 运行，不本地 build）
# BACKEND_IMAGE=registry.cn-hangzhou.aliyuncs.com/<namespace>/easy-agent-backend:v1.3
# FRONTEND_IMAGE=registry.cn-hangzhou.aliyuncs.com/<namespace>/easy-agent-frontend:v1.3
BACKEND_IMAGE=
FRONTEND_IMAGE=

# 可选：若要脚本自动 docker login，请填写
# ACR_USERNAME=
# ACR_PASSWORD=

MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=agent_scaffold_lite
MYSQL_USER=easy_agent
MYSQL_PASSWORD=change_me_app_password
MYSQL_PORT=13306

BACKEND_PORT=8091
FRONTEND_PORT=3000
BACKEND_JAVA_OPTS=-Xms512m -Xmx1024m

# Must be reachable by the user's browser.
# Example:
# PUBLIC_BASE_URL=http://203.0.113.10
# PUBLIC_BASE_URL=https://agent.example.com
PUBLIC_BASE_URL=http://your-server-ip-or-domain

GATEWAY_PORT=80

# Required for AI calls
DASHSCOPE_API_KEY=replace_with_your_dashscope_api_key

# Reuse mode only (DEPLOY_MODE=reuse)
# EXTERNAL_DB_URL=jdbc:mysql://your-mysql-host:3306/agent_scaffold_lite?useUnicode=true&characterEncoding=utf8&autoReconnect=true&zeroDateTimeBehavior=convertToNull&serverTimezone=UTC&useSSL=false&allowPublicKeyRetrieval=true
EXTERNAL_DB_URL=
EXTERNAL_DB_USERNAME=
EXTERNAL_DB_PASSWORD=
EXTERNAL_DB_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
